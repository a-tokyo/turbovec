#!/usr/bin/env sh
# Pre-commit hook for turbovec-node (installed by husky v9).
#
# Mechanism: turbovec-node/package.json's "prepare" script runs husky with the
# path `turbovec-node/.husky`, which tells git `core.hooksPath` to point at
# `turbovec-node/.husky/_` (relative to the repo root). The husky wrapper
# (`_/pre-commit` → `_/h`) then delegates here. Git always runs hooks from the
# repo root, so every path below is explicit.
#
# Guard: if no staged files are under turbovec-node/, skip immediately so that
# Rust, Python, or docs-only commits are not blocked by the Node.js checks.
git diff --cached --name-only | grep -q '^turbovec-node/' || exit 0

# Run only the fast static checks — format, lint, types.
# Tests are intentionally excluded from the hook (covered in CI).
cd turbovec-node
npm run format:check && npm run lint && npm run typecheck
